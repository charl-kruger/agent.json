{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "agent-inbox",
  "main": "src/server.ts",
  "compatibility_date": "2026-03-02",
  "compatibility_flags": ["nodejs_compat"],
  "ai": {
    "binding": "AI",
    "remote": true
  },
  "send_email": [
    {
      "name": "EMAIL",
      "remote": true
    }
  ],
  "assets": {
    "directory": "./public",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/agents/*", "/api/*", "/.well-known/*"]
  },
  "durable_objects": {
    "bindings": [
      {
        "class_name": "InboxAgent",
        "name": "InboxAgent"
      }
    ]
  },
  "migrations": [
    {
      "new_sqlite_classes": ["InboxAgent"],
      "tag": "v1"
    }
  ],
  "observability": {
    "enabled": true
  }
}
